# 감사노트 환경변수 예시
# 이 파일을 .env.local 로 복사하여 실제 값을 입력하세요.
# .env.local 은 Git에 커밋되지 않습니다.

# ── 광고 설정 (Google AdSense) ──────────────────────────────────
# 두 값이 모두 설정된 경우에만 실제 광고가 표시됩니다.
# 미설정 시 "광고 영역" 플레이스홀더가 표시됩니다.

# Google AdSense Publisher ID
# 형식: ca-pub-0000000000000000
VITE_ADMOB_APP_ID=

# AdSense Ad Unit ID (배너 슬롯 ID)
# 형식: 0000000000
VITE_ADMOB_BANNER_ID=
