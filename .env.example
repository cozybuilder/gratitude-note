# 감사노트 환경변수 예시
# 이 파일을 .env.local 로 복사하여 실제 값을 입력하세요.
# .env.local 은 Git에 커밋되지 않습니다.

# ── 광고 설정 (Google AdSense) ──────────────────────────────────
# 두 값이 모두 설정된 경우에만 실제 광고가 표시됩니다.
# 미설정 시 "광고 영역" 플레이스홀더가 표시됩니다.

# Google AdSense Publisher ID
# 형식: ca-pub-0000000000000000
VITE_ADMOB_APP_ID=

# AdSense Ad Unit ID (배너 슬롯 ID)
# 형식: 0000000000
VITE_ADMOB_BANNER_ID=

# ── AI 배지 축하 메시지 (v1.7.1) ────────────────────────────────
# Vercel Serverless Function 엔드포인트 URL
# 설정 시: 배지 획득 축하 메시지를 AI(OpenAI)로 생성합니다.
# 미설정 시: 로컬 템플릿 메시지로 대체됩니다. (앱 동작에는 영향 없음)
# OPENAI_API_KEY 는 절대 여기에 넣지 마세요 — Vercel 대시보드 환경변수에만 설정합니다.
# 형식: https://your-project.vercel.app/api/badge-celebration
VITE_BADGE_AI_ENDPOINT=
